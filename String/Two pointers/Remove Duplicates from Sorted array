from typing import List
class Solution:
    def removeDuplicates(self, nums: List[int]) -> int:
        # Two pointer approach
        if not nums:
            return 0                   # in case of empty array
        j=0
        for i in range(1,len(nums)):
          if nums[j]!=nums[i]:
             j+=1
             nums[j]=nums[i]
        return j+1
if __name__ =="__main__":
    sol=Solution()
    nums=[1,1,2]
    print(sol.removeDuplicates(nums))
